{
  "name": "tailwind",
  "version": "1.0.0",
  "description": "Tailwind CSS v4 playground with Vite, utility-first styling, and gradient examples",
  "type": "framework",
  "framework": "custom",
  "variables": [
    {"name": "project_name", "description": "Project name", "default": "", "required": true},
    {"name": "author", "description": "Author name", "default": "", "required": false},
    {"name": "version", "description": "Project version", "default": "1.0.0", "required": false},
    {"name": "description", "description": "Project description", "default": "A Tailwind CSS project", "required": false}
  ],
  "commands": {
    "pre_copy": [], "post_copy": ["npm install"],
    "setup": ["echo 'Tailwind project created!'", "echo 'Run: npm run dev'"]
  },
  "dependencies": {
    "python": [], "node": ["tailwindcss", "vite"], "system": ["node >= 18"]
  },
  "required_files": ["package.json", "index.html", "vite.config.js"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store", "node_modules", "dist"],
  "metadata": {
    "author": "APD", "created": "2026-06-30T13:00:00", "modified": "2026-06-30T13:00:00",
    "tags": ["css", "tailwind", "vite", "design"], "category": "styling"
  }
}
