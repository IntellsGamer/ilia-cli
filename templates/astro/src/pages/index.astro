---
const title = '{{ project_name }}'
const desc = '{{ description }}'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={desc} />
  </head>
  <body>
    <h1>{title}</h1>
    <p>{desc}</p>
  </body>
</html>
