{
  "name": "streamlit",
  "version": "1.0.0",
  "description": "Streamlit data dashboard with metrics, dataframes, columns layout, and interactive widgets",
  "type": "framework",
  "framework": "custom",
  "variables": [
    {"name": "project_name", "description": "Dashboard name", "default": "", "required": true},
    {"name": "author", "description": "Author name", "default": "", "required": false},
    {"name": "version", "description": "Dashboard version", "default": "1.0.0", "required": false},
    {"name": "description", "description": "Dashboard description", "default": "A Streamlit dashboard", "required": false}
  ],
  "commands": {
    "pre_copy": [],
    "post_copy": [
      "pip install -r requirements.txt"
    ],
    "setup": [
      "echo 'Streamlit project {{ project_name }} created!'",
      "echo 'Run: streamlit run app.py'"
    ]
  },
  "dependencies": {
    "python": ["streamlit", "pandas"],
    "node": [],
    "system": []
  },
  "required_files": ["app.py", "requirements.txt"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store", "venv", ".venv", "env"],
  "metadata": {
    "author": "APD",
    "created": "2026-06-30T13:00:00",
    "modified": "2026-06-30T13:00:00",
    "tags": ["dashboard", "python", "streamlit", "data"],
    "category": "dashboard"
  }
}
