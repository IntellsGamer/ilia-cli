{
  "name": "graphql-api",
  "version": "1.0.0",
  "description": "Strawberry GraphQL API with FastAPI, auto-generated schema, and interactive playground",
  "type": "framework",
  "framework": "fastapi",
  "variables": [
    {"name": "project_name", "description": "API name", "default": "", "required": true},
    {"name": "author", "description": "Author name", "default": "", "required": false},
    {"name": "version", "description": "API version", "default": "1.0.0", "required": false},
    {"name": "description", "description": "API description", "default": "A GraphQL API", "required": false},
    {"name": "port", "description": "Server port", "default": "8000", "required": false}
  ],
  "commands": {
    "pre_copy": [], "post_copy": ["pip install -r requirements.txt"],
    "setup": ["echo 'GraphQL API created!'", "echo 'Run: python app.py'"]
  },
  "dependencies": {
    "python": ["fastapi", "strawberry-graphql", "uvicorn"], "node": [], "system": []
  },
  "required_files": ["app.py", "schema.py", "requirements.txt"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store", "venv", ".venv"],
  "metadata": {
    "author": "APD", "created": "2026-06-30T13:00:00", "modified": "2026-06-30T13:00:00",
    "tags": ["api", "graphql", "python", "fastapi", "strawberry"], "category": "api-server"
  }
}
