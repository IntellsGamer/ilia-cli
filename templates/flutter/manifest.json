  "dependencies": {
    "python": [], "node": [], "system": ["flutter >= 3.24", "dart >= 3.5"]
  },
  "required_files": ["pubspec.yaml", "lib/main.dart"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store", ".dart_tool", "build", ".packages"],
  "metadata": {
