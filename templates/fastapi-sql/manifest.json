{
  "name": "fastapi-sql",
  "version": "1.0.0",
  "description": "FastAPI with async SQLAlchemy ORM, SQLite, auto-migrations, and CRUD endpoints",
  "type": "framework",
  "framework": "fastapi",
  "variables": [
    {"name": "project_name", "description": "API name", "default": "", "required": true},
    {"name": "author", "description": "Author name", "default": "", "required": false},
    {"name": "version", "description": "API version", "default": "1.0.0", "required": false},
    {"name": "description", "description": "API description", "default": "FastAPI + SQLAlchemy", "required": false},
    {"name": "port", "description": "Server port", "default": "8000", "required": false}
  ],
  "commands": {
    "pre_copy": [], "post_copy": ["pip install -r requirements.txt"],
    "setup": ["echo 'FastAPI SQL project created!'", "echo 'Run: python app.py'"]
  },
  "dependencies": {
    "python": ["fastapi", "sqlalchemy", "aiosqlite", "uvicorn"], "node": [], "system": []
  },
  "required_files": ["app.py", "requirements.txt"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store", "venv", ".venv", "*.db"],
  "metadata": {
    "author": "APD", "created": "2026-06-30T13:00:00", "modified": "2026-06-30T13:00:00",
    "tags": ["api", "fastapi", "sqlalchemy", "orm", "async"], "category": "api-server"
  }
}
