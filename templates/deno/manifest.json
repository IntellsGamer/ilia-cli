{
  "name": "deno",
  "version": "1.0.0",
  "description": "Deno web server with Oak framework, TypeScript-native runtime, and task runner",
  "type": "framework",
  "framework": "custom",
  "variables": [
    {"name": "project_name", "description": "App name", "default": "", "required": true},
    {"name": "author", "description": "Author name", "default": "", "required": false},
    {"name": "version", "description": "App version", "default": "1.0.0", "required": false},
    {"name": "description", "description": "App description", "default": "A Deno app", "required": false},
    {"name": "port", "description": "Server port", "default": "8000", "required": false}
  ],
  "commands": {
    "pre_copy": [], "post_copy": [],
