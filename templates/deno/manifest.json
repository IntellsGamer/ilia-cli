  "dependencies": {
    "python": [], "node": [], "system": ["deno >= 1.40"]
  },
  "required_files": ["deno.json", "main.ts"],
  "ignore_patterns": [".git", "__pycache__", "*.pyc", ".DS_Store"],
  "metadata": {
    "author": "APD", "created": "2026-06-30T13:00:00", "modified": "2026-06-30T13:00:00",
